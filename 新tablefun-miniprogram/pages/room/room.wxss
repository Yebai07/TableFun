/* pages/room/room.wxss */
.room-container {
  height: 100vh;
  background-color: #1a1a2e;
  display: flex;
  flex-direction: column;
  padding-top: calc(var(--status-bar-height) + var(--nav-bar-height));
}

/* 等待阶段 */
.waiting-phase {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 100rpx;
}

/* 房间信息卡片 */
.room-info-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.room-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.room-status {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-waiting {
  background: rgba(46, 204, 113, 0.2);
  color: #2ecc71;
}

.room-script {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.room-script-cover {
  width: 100rpx;
  height: 140rpx;
  border-radius: 12rpx;
}

.room-script-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.script-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.script-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.room-settings {
  display: flex;
  gap: 12rpx;
}

.setting-tag {
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 玩家列表 */
.players-section {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.players-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.player-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.player-avatar {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.player-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

.role-badge {
  padding: 4rpx 12rpx;
  background: rgba(232, 69, 69, 0.2);
  color: #e84545;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.player-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.player-status.ready {
  color: #2ecc71;
}

.player-badge {
  padding: 4rpx 12rpx;
  background: rgba(232, 69, 69, 0.2);
  color: #e84545;
  border-radius: 8rpx;
  font-size: 20rpx;
}

/* 角色分配 */
.characters-section {
  margin-bottom: 30rpx;
}

.character-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.character-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.character-option:active {
  background: rgba(232, 69, 69, 0.1);
}

.character-avatar {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
}

.character-avatar.assigned {
  opacity: 0.5;
}

.character-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.character-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
}

.character-gender {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.character-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 30rpx;
}

.btn-leave,
.btn-ready,
.btn-start {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-leave {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.btn-ready {
  background: rgba(46, 204, 113, 0.2);
  color: #2ecc71;
}

.btn-start {
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  font-weight: bold;
}

/* 游戏中阶段 */
.playing-phase {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.game-phase-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(232, 69, 69, 0.1);
  border-bottom: 1rpx solid rgba(232, 69, 69, 0.2);
}

.phase-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.phase-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #e84545;
}

.game-content {
  flex: 1;
  padding: 30rpx;
}

/* 剧本内容 */
.script-content {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
}

.script-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.role-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #e84545;
  margin-bottom: 8rpx;
}

.role-gender {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.script-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.9);
}

/* 线索卡 */
.clue-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.clue-card {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border-left: 4rpx solid #e84545;
}

.clue-number {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #e84545;
  margin-bottom: 12rpx;
}

.clue-content {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

/* 投票 */
.vote-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vote-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.vote-avatar {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
}

.vote-name {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
}

.vote-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 游戏结果 */
.result-section {
  text-align: center;
  padding: 40rpx 0;
}

.result-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #f7b731;
  margin-bottom: 30rpx;
}

.result-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 40rpx;
}

.reveal-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reveal-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.reveal-name {
  font-size: 26rpx;
  color: #fff;
}

.reveal-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

.reveal-character {
  font-size: 26rpx;
  color: #e84545;
  font-weight: bold;
}

/* 游戏操作 */
.game-actions {
  display: flex;
  padding: 20rpx 30rpx;
  background: rgba(0, 0, 0, 0.3);
}

.btn-action {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 聊天区域 */
.chat-section {
  height: 400rpx;
  background: rgba(0, 0, 0, 0.3);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.chat-messages {
  height: 320rpx;
  padding: 16rpx;
}

.chat-message {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.message-avatar {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #fff;
  flex-shrink: 0;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.message-sender {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.message-text {
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.1);
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.message-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  align-self: flex-end;
}

.chat-input-bar {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.chat-input {
  flex: 1;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  padding: 0 24rpx;
  color: #fff;
  font-size: 24rpx;
}

.btn-send {
  height: 60rpx;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 24rpx;
}
