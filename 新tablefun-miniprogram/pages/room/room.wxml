<!--pages/room/room.wxml-->
<view class="room-container">
  <!-- 自定义导航栏 -->
  <custom-navbar city="游戏房间" bindcitytap="" />

  <!-- 等待阶段 -->
  <view wx:if="{{gamePhase === 'waiting'}}" class="waiting-phase">
    <!-- 房间信息 -->
    <view class="room-info-card">
      <view class="room-header">
        <text class="room-name">{{room.name}}</text>
        <view class="room-status status-waiting">等待中</view>
      </view>
      <view class="room-script">
        <image class="room-script-cover" src="{{room.script.cover}}" mode="aspectFill" />
        <view class="room-script-details">
          <text class="script-name">{{room.script.name}}</text>
          <text class="script-meta">{{room.script.type}} | {{room.script.playerCount}}人 | {{room.script.duration}}h</text>
        </view>
      </view>
      <view class="room-settings">
        <text class="setting-tag">{{room.enableVoice ? '🎤 语音房' : '💬 文字房'}}</text>
        <text class="setting-tag" wx:if="{{room.password}}">🔒 密码房</text>
      </view>
    </view>

    <!-- 玩家列表 -->
    <view class="players-section">
      <text class="section-title">👥 玩家列表 ({{players.length}}/{{room.maxPlayers}})</text>
      <view class="players-grid">
        <view class="player-item" wx:for="{{players}}" wx:key="id">
          <view class="player-avatar">{{item.nickname.charAt(0)}}</view>
          <view class="player-info">
            <text class="player-name">{{item.nickname}}</text>
            <view class="player-role" wx:if="{{item.role}}">
              <text class="role-badge">{{item.role}}</text>
            </view>
            <text class="player-status {{item.isReady ? 'ready' : ''}}" wx:else>
              {{item.isReady ? '已准备' : '未准备'}}
            </text>
          </view>
          <view class="player-badge" wx:if="{{item.isOwner}}">房主</view>
        </view>
      </view>
    </view>

    <!-- 角色分配 -->
    <view class="characters-section" wx:if="{{room.script.characters && room.script.characters.length > 0}}">
      <text class="section-title">🎭 角色分配</text>
      <view class="character-options">
        <view class="character-option" wx:for="{{room.script.characters}}" wx:key="name" bindtap="selectCharacter" data-char="{{item}}" wx:if="{{!item.assigned || item.assigned === app.globalData.userId}}">
          <view class="character-avatar {{item.assigned ? 'assigned' : ''}}">{{item.name.charAt(0)}}</view>
          <view class="character-info">
            <text class="character-name">{{item.name}}</text>
            <text class="character-gender">{{item.gender}}</text>
          </view>
          <view class="character-status">
            <text wx:if="{{item.assigned}}">已选</text>
            <text wx:else class="unassigned">可选</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn-leave" bindtap="leaveRoom">离开房间</button>
      <button class="btn-ready" bindtap="toggleReady">{{isReady ? '取消准备' : '准备'}}</button>
      <button class="btn-start" wx:if="{{isOwner && canStartGame}}" bindtap="startGame">开始游戏</button>
    </view>
  </view>

  <!-- 游戏中阶段 -->
  <view wx:if="{{gamePhase === 'playing'}}" class="playing-phase">
    <!-- 游戏阶段提示 -->
    <view class="game-phase-bar">
      <text class="phase-label">当前阶段</text>
      <text class="phase-name">{{currentPhaseName}}</text>
    </view>

    <!-- 剧本内容区域 -->
    <scroll-view class="game-content" scroll-y>
      <!-- 角色剧本 -->
      <view wx:if="{{gameStage === 'read' && myRole}}" class="script-content">
        <view class="script-header">
          <text class="role-title">你的角色：{{myRole.name}}</text>
          <text class="role-gender">{{myRole.gender}}</text>
        </view>
        <text class="script-text">{{myRole.content}}</text>
      </view>

      <!-- 线索卡 -->
      <view wx:if="{{gameStage === 'clues'}}" class="clues-section">
        <text class="section-title">🔍 线索卡</text>
        <view class="clue-cards">
          <view class="clue-card" wx:for="{{myClues}}" wx:key="id">
            <view class="clue-number">线索{{item.number}}</view>
            <text class="clue-content">{{item.content}}</text>
          </view>
        </view>
      </view>

      <!-- 投票 -->
      <view wx:if="{{gameStage === 'vote'}}" class="vote-section">
        <text class="section-title">🗳️ 投票环节</text>
        <view class="vote-list">
          <view class="vote-item" wx:for="{{voteOptions}}" wx:key="id" bindtap="castVote" data-id="{{item.id}}">
            <view class="vote-avatar">{{item.name.charAt(0)}}</view>
            <text class="vote-name">{{item.name}}</text>
            <view class="vote-count">{{item.votes}}票</view>
          </view>
        </view>
      </view>

      <!-- 游戏结果 -->
      <view wx:if="{{gameStage === 'result'}}" class="result-section">
        <text class="result-title">🎉 游戏结束</text>
        <view class="result-content">
          <text class="result-text">{{gameResult}}</text>
        </view>
        <view class="result-reveal" wx:if="{{revealedRoles}}">
          <text class="section-title">🎭 角色揭秘</text>
          <view class="reveal-list">
            <view class="reveal-item" wx:for="{{revealedRoles}}" wx:key="playerId">
              <text class="reveal-name">{{item.playerName}}</text>
              <text class="reveal-role">→</text>
              <text class="reveal-character">{{item.characterName}}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 游戏操作栏 -->
    <view class="game-actions">
      <button wx:if="{{gameStage === 'read'}}" class="btn-action" bindtap="finishReading">阅读完成</button>
      <button wx:if="{{gameStage === 'clues'}}" class="btn-action" bindtap="showCluesExchange">线索交换</button>
      <button wx:if="{{gameStage === 'discuss'}}" class="btn-action" bindtap="startVoting">开始投票</button>
      <button wx:if="{{gameStage === 'result'}}" class="btn-action" bindtap="leaveRoom">返回首页</button>
    </view>
  </view>

  <!-- 聊天区域 -->
  <view class="chat-section" wx:if="{{room.enableVoice || gamePhase === 'playing'}}">
    <view class="chat-messages" scroll-y scroll-into-view="{{scrollToMessage}}">
      <view class="chat-message" wx:for="{{messages}}" wx:key="id">
        <view class="message-avatar">{{item.senderName.charAt(0)}}</view>
        <view class="message-content">
          <text class="message-sender">{{item.senderName}}</text>
          <text class="message-text">{{item.text}}</text>
        </view>
        <text class="message-time">{{item.time}}</text>
      </view>
    </view>
    <view class="chat-input-bar">
      <input class="chat-input" placeholder="输入消息..." bindinput="onChatInput" value="{{chatText}}" />
      <button class="btn-send" bindtap="sendChatMessage" size="mini">发送</button>
    </view>
  </view>
</view>
