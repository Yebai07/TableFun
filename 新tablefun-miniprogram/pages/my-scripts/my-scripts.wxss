/* pages/my-scripts/my-scripts.wxss */
.my-scripts-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
  padding-top: 0;
}

/* 个人信息 */
.personal-info {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  gap: 16rpx;
}

.info-avatar {
  margin-right: 24rpx;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: #f5f5f5;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.info-coins {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-left: 8rpx;
}

.coins-icon {
  font-size: 48rpx;
}

.coins-count {
  font-size: 52rpx;
  font-weight: bold;
  color: #FF6B35;
}

.info-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #666;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.info-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 菜单列表 */
.menu-list {
  padding: 0 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  flex: 1;
  min-width: calc(50% - 8rpx);
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-count {
  font-size: 24rpx;
  color: #e84545;
  margin-right: 12rpx;
}

.menu-status {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}
