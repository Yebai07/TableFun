/* pages/home/home.wxss - 清新白色主题 */
.home-container {
  min-height: 100vh;
  background-color: #fff;
  padding: 0;
  padding-bottom: 100rpx;
  padding-top: calc(var(--status-bar-height) + var(--nav-bar-height) + 20rpx);
}

/* 轮播图容器 */
.banner-section {
  padding: 0 20rpx;
}

.fixed-filter-bar .filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}

.fixed-filter-bar .filter-item.active {
  background: #4CAF50;
  color: #fff;
}

.fixed-filter-bar .filter-text {
  font-size: 26rpx;
}

.fixed-filter-bar .filter-arrow {
  font-size: 16rpx;
}

/* 城市选择器 */
.city-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  color: #fff;
  font-size: 26rpx;
  flex-shrink: 0;
}

.city-icon {
  font-size: 24rpx;
}

.city-name {
  font-weight: bold;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.city-arrow {
  font-size: 16rpx;
}

/* 搜索栏 */
.search-bar {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  width: 100%;
  height: 70rpx;
  background: #fff;
  border-radius: 35rpx;
  padding: 0 90rpx 0 30rpx;
  color: #333;
  font-size: 26rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.placeholder {
  color: #999;
}

.search-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
}

.search-icon-text {
  font-size: 36rpx;
  color: #ccc;
  opacity: 0.6;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.action-text {
  font-size: 24rpx;
  color: #333;
}

/* 发活动按钮 */
.activity-button {
  position: fixed;
  right: 30rpx;
  bottom: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  z-index: 50;
}

.activity-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #FF5722 0%, #FF9800 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 87, 34, 0.4);
  border: 4rpx solid #fff;
}

.activity-text {
  font-size: 22rpx;
  color: #FF5722;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.95);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 搜索历史面板 */
.search-history-panel {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  overflow: hidden;
  margin-top: 8rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #fafafa;
}

.history-title {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.history-clear {
  font-size: 24rpx;
  color: #4CAF50;
}

.history-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.history-item:active {
  background: #f5f5f5;
}

.history-text {
  font-size: 26rpx;
  color: #999;
  flex: 1;
  opacity: 0.85;
}

.history-delete {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #ccc;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.history-empty {
  padding: 80rpx 0;
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-bar.fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  margin: 0;
  border-radius: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}

.filter-scroll {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
}

.filter-scroll .filter-item {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.filter-scroll .filter-item.active {
  background: #4CAF50;
  color: #fff;
}

/* 轮播图 */
.banner-swiper {
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.banner-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.action-text {
  font-size: 24rpx;
  color: #333;
}

/* 区域 */
.section {
  margin-bottom: 40rpx;
  padding: 20rpx;
  padding-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #4CAF50;
}

/* 剧本滚动 */
.script-scroll {
  white-space: nowrap;
}

.script-card {
  display: inline-block;
  width: 280rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-right: 24rpx;
  vertical-align: top;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.script-cover {
  width: 100%;
  height: 360rpx;
}

.script-info {
  padding: 20rpx;
}

.script-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.script-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.script-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #666;
}

.script-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-score {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF9800;
}

.rating-stars {
  font-size: 24rpx;
  color: #FF9800;
}

.rating-count {
  font-size: 22rpx;
  color: #999;
}

/* 房间列表 */
.room-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.room-cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.room-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.room-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-script {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-text {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.status-playing {
  background: #FFEBEE;
  color: #F44336;
}

.status-waiting {
  background: #E8F5E9;
  color: #4CAF50;
}

.room-time,
.room-players {
  font-size: 24rpx;
  color: #666;
}

.room-badges {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.room-badge {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.badge-special {
  background: #FFF3E0;
  color: #FF9800;
}

.badge-urgent {
  background: #FFEBEE;
  color: #F44336;
}

.badge-full {
  background: #E3F2FD;
  color: #2196F3;
}

/* 剧本价格 */
.room-price {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: 600;
  margin-bottom: 8rpx;
}

/* 拼车记录 */
.carpool-record {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #eee;
}

.carpool-title {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.carpool-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 8rpx 0;
}

.carpool-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
}

.carpool-row-gray {
  color: #999;
}

.carpool-row-black {
  color: #333;
}

.carpool-shop {
  font-size: 24rpx;
}

.carpool-distance {
  font-size: 24rpx;
}

.carpool-datetime {
  font-size: 24rpx;
}

.carpool-needed {
  font-size: 24rpx;
  color: #FF5722;
  font-weight: 500;
}

.room-enter {
  width: 60rpx;
  height: 60rpx;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #4CAF50;
  flex-shrink: 0;
}

/* 最新剧本 */
.new-script-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.new-script-cover {
  width: 140rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.new-script-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.new-script-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.new-script-intro {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.new-script-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.new-script-time {
  font-size: 22rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.city-modal,
.type-modal,
.sort-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  max-height: 70vh;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
  z-index: 101;
}

/* 下拉弹窗样式 */
.dropdown-modal {
  bottom: auto !important;
  left: 20rpx !important;
  right: 20rpx !important;
  margin-top: 180rpx;
  border-radius: 16rpx !important;
  max-height: 60vh;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.date-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  z-index: 101;
}

.dropdown-modal {
  top: auto;
  left: 20rpx;
  right: 20rpx;
  bottom: auto;
  margin-top: 180rpx;
  max-height: 70vh;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

/* 城市列表 */
.city-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.city-section {
  margin-bottom: 30rpx;
}

.city-letter {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.city-items,
.district-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.district-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  max-height: 50vh;
}

.city-item {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.city-item.active {
  background: #4CAF50;
  color: #fff;
}

/* 日期选择 */
.date-list {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

.date-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.date-item.active {
  background: #4CAF50;
  color: #fff;
}

.date-label {
  font-size: 28rpx;
  font-weight: bold;
}

.date-sub {
  font-size: 24rpx;
  color: #999;
}

.date-item.active .date-sub {
  color: rgba(255, 255, 255, 0.8);
}

/* 类型选择 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 20rpx;
}

.type-grid-item {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
}

.type-grid-item.active {
  background: #4CAF50;
  color: #fff;
}

/* 排序选择 */
.sort-list {
  padding: 20rpx;
}

.sort-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.sort-item.active {
  background: #E8F5E9;
}

.sort-label {
  font-size: 28rpx;
  color: #333;
}

.sort-item.active .sort-label {
  color: #4CAF50;
  font-weight: bold;
}

.sort-icon {
  font-size: 32rpx;
  color: #4CAF50;
}
