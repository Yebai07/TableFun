<!--pages/real-name-auth/real-name-auth.wxml-->
<view class="auth-container" style="padding-top: {{statusBarHeight + navBarHeight}}px;">
  <!-- 自定义导航栏 -->
  <custom-navbar showBack="{{true}}" city="个人实名认证" bind:backtap="goBack" />

  <!-- 认证状态 -->
  <view class="status-card {{isAuthenticated ? 'authenticated' : 'unauthenticated'}}">
    <view class="status-icon">{{isAuthenticated ? '✅' : '⚠️'}}</view>
    <view class="status-text">{{isAuthenticated ? '已认证' : '未认证'}}</view>
    <view class="status-desc">{{isAuthenticated ? '您已完成实名认证' : '请完成实名认证以享受完整服务'}}</view>
  </view>

  <!-- 认证表单 -->
  <view class="auth-form" wx:if="{{!isAuthenticated}}">
    <view class="form-title">实名信息</view>

    <view class="form-item">
      <text class="form-label">真实姓名</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{formData.realName}}" bindinput="onRealNameInput" placeholder-class="placeholder" />
    </view>

    <view class="form-item">
      <text class="form-label">身份证号</text>
      <input class="form-input" placeholder="请输入身份证号" value="{{formData.idCard}}" bindinput="onIdCardInput" maxlength="18" placeholder-class="placeholder" type="idcard" />
    </view>

    <view class="form-tips">
      <text class="tips-icon">💡</text>
      <text class="tips-text">您的信息将严格保密，仅用于实名认证</text>
    </view>

    <button class="submit-btn" bindtap="submitAuth" disabled="{{isSubmitting}}">
      {{isSubmitting ? '提交中...' : '提交认证'}}
    </button>
  </view>

  <!-- 认证成功信息 -->
  <view class="auth-info" wx:if="{{isAuthenticated}}">
    <view class="info-item">
      <text class="info-label">认证姓名：</text>
      <text class="info-value">{{authInfo.realName}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">身份证号：</text>
      <text class="info-value">{{authInfo.idCard}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">认证时间：</text>
      <text class="info-value">{{authInfo.authTime}}</text>
    </view>
  </view>
</view>
