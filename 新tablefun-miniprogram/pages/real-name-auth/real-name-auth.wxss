/* pages/real-name-auth/real-name-auth.wxss */
.auth-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 状态卡片 */
.status-card {
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.status-card.authenticated {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
}

.status-card.unauthenticated {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 认证表单 */
.auth-form {
  margin: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #999;
}

.form-tips {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #FFF3E0;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: #E65100;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  border: none;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 认证信息 */
.auth-info {
  margin: 20rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
}

.info-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 200rpx;
  font-size: 28rpx;
  color: #666;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
