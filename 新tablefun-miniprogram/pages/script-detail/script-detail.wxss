/* pages/script-detail/script-detail.wxss */
.detail-container {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 140rpx;
  padding-top: 0;
}

/* 封面图 */
.script-cover {
  width: 100%;
  height: 500rpx;
  display: block;
}

/* 信息区 */
.info-section {
  padding: 30rpx;
  background: linear-gradient(to bottom, transparent, #fff 50rpx);
  margin-top: -50rpx;
  position: relative;
  border-radius: 30rpx 30rpx 0 0;
}

.script-header {
  margin-bottom: 30rpx;
}

.script-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.script-name {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.3;
}

.collect-btn {
  font-size: 48rpx;
  color: #f7b731;
  padding-left: 20rpx;
}

.script-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  background: #f5f5f5;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #e84545;
}

/* 价格行 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #e84545;
}

.price-value.free {
  color: #2ecc71;
}

/* 拼车区域 */
.carpool-section {
  margin-bottom: 40rpx;
}

.carpool-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.carpool-item {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.08) 0%, rgba(76, 175, 80, 0.02) 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

.carpool-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.carpool-row:last-child {
  margin-bottom: 0;
}

.carpool-shop {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.carpool-distance {
  font-size: 24rpx;
  color: #999;
}

.carpool-time {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.carpool-seats {
  font-size: 28rpx;
  color: #e84545;
  font-weight: bold;
}

.no-carpool {
  padding: 60rpx 0;
  text-align: center;
}

.no-carpool-text {
  font-size: 28rpx;
  color: #999;
}

/* 区域 */
.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.section-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
}

/* 角色列表 */
.character-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.character-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
}

.character-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  flex-shrink: 0;
}

.character-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.character-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.character-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.character-gender {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  background: #e0e0e0;
  border-radius: 12rpx;
}

/* 亮点特色 */
.features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(46, 204, 113, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2ecc71;
  font-size: 24rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: 28rpx;
  color: #666;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-top: 1rpx solid #e0e0e0;
  backdrop-filter: blur(10rpx);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
}

.action-btn.primary {
  flex: 2;
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  font-weight: bold;
}

.action-btn.secondary {
  flex: 1;
  background: #f5f5f5;
  flex-direction: column;
  gap: 4rpx;
  color: #333;
}

.btn-icon {
  font-size: 32rpx;
}

/* 评价区域 */
.reviews-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.reviews-count {
  font-size: 24rpx;
  color: #999;
}

/* 筛选按钮 */
.review-filters {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  padding: 4rpx 0;
}

.review-filters::-webkit-scrollbar {
  display: none;
}

.filter-btn {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.filter-btn.active {
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
}

.review-summary {
  display: flex;
  gap: 30rpx;
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.overall-rating {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-width: 140rpx;
}

.rating-score {
  font-size: 56rpx;
  font-weight: bold;
  color: #f7b731;
  line-height: 1;
}

.rating-star {
  font-size: 28rpx;
  color: #f7b731;
}

.rating-distribution {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.rating-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bar-label {
  font-size: 22rpx;
  color: #999;
  min-width: 60rpx;
}

.bar-track {
  flex: 1;
  height: 12rpx;
  background: #e0e0e0;
  border-radius: 6rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #f7b731 0%, #f39c12 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-item {
  padding: 30rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.review-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e0e0e0;
  flex-shrink: 0;
}

.review-user {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.review-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.review-time {
  font-size: 22rpx;
  color: #999;
}

.review-rating {
  font-size: 24rpx;
  color: #f7b731;
  font-weight: 500;
}

.review-content {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #666;
  margin-bottom: 16rpx;
}

.review-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.review-tag {
  padding: 8rpx 20rpx;
  background: rgba(76, 175, 80, 0.15);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #4CAF50;
}

.no-reviews {
  padding: 80rpx 0;
  text-align: center;
}

.no-reviews-text {
  font-size: 28rpx;
  color: #999;
}
