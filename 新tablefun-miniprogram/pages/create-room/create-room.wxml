<!--pages/create-room/create-room.wxml-->
<view class="create-room-container">
  <!-- 自定义导航栏 -->
  <custom-navbar city="创建房间" bindcitytap="" />

  <!-- 剧本选择 -->
  <view class="section">
    <text class="section-title">📚 选择剧本</text>
    <view class="script-selector" bindtap="selectScript">
      <view wx:if="{{selectedScript.name}}">
        <image class="selected-script-cover" src="{{selectedScript.cover}}" mode="aspectFill" />
        <view class="selected-script-info">
          <text class="selected-script-name">{{selectedScript.name}}</text>
          <view class="selected-script-tags">
            <text class="tag tag-type">{{selectedScript.type}}</text>
            <text class="tag tag-player">{{selectedScript.playerCount}}人</text>
          </view>
        </view>
      </view>
      <view wx:else class="script-placeholder">
        <text class="placeholder-icon">📖</text>
        <text class="placeholder-text">点击选择剧本</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>

  <!-- 房间信息 -->
  <view class="section">
    <text class="section-title">🏠 房间信息</text>

    <view class="form-item">
      <text class="form-label">房间名称</text>
      <input class="form-input" placeholder="请输入房间名称" value="{{roomName}}" bindinput="onRoomNameInput" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="form-label">游戏密码</text>
      <input class="form-input" placeholder="选填，不填则为公开房间" value="{{roomPassword}}" bindinput="onRoomPasswordInput" maxlength="6" />
    </view>

    <view class="form-item">
      <text class="form-label">房间说明</text>
      <textarea class="form-textarea" placeholder="请输入房间说明，如：新手友好、语音房等" value="{{roomDesc}}" bindinput="onRoomDescInput" maxlength="100" />
    </view>
  </view>

  <!-- 游戏设置 -->
  <view class="section">
    <text class="section-title">⚙️ 游戏设置</text>

    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-label">是否公开</text>
        <text class="setting-desc">公开房间其他玩家可见</text>
      </view>
      <switch class="setting-switch" checked="{{isPublic}}" bindchange="onPublicChange" color="#e84545" />
    </view>

    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-label">是否语音</text>
        <text class="setting-desc">开启语音可实时交流</text>
      </view>
      <switch class="setting-switch" checked="{{enableVoice}}" bindchange="onVoiceChange" color="#e84545" />
    </view>

    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-label">自动开始</text>
        <text class="setting-desc">人数满后自动开始游戏</text>
      </view>
      <switch class="setting-switch" checked="{{autoStart}}" bindchange="onAutoStartChange" color="#e84545" />
    </view>
  </view>

  <!-- 角色分配 -->
  <view class="section" wx:if="{{selectedScript.name}}">
    <text class="section-title">👥 角色分配</text>
    <view class="character-selection">
      <view class="character-option" wx:for="{{selectedScript.characters}}" wx:key="name">
        <view class="character-avatar">{{item.name.charAt(0)}}</view>
        <view class="character-info">
          <text class="character-name">{{item.name}}</text>
          <text class="character-gender">{{item.gender}}</text>
        </view>
        <view class="character-player">
          <text wx:if="{{item.assigned}}">{{item.assigned}}</text>
          <text wx:else class="unassigned">未分配</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 创建按钮 -->
  <view class="create-btn-container">
    <button class="btn-create" bindtap="createRoom" disabled="{{!selectedScript.name}}">
      创建房间
    </button>
  </view>
</view>

<!-- 剧本选择弹窗 -->
<view class="modal-mask" wx:if="{{showScriptModal}}" bindtap="hideScriptModal">
  <view class="script-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">选择剧本</text>
      <text class="modal-close" bindtap="hideScriptModal">✕</text>
    </view>

    <scroll-view class="script-list-scroll" scroll-y>
      <view class="modal-script-item" wx:for="{{scripts}}" wx:key="id" bindtap="confirmSelectScript" data-script="{{item}}">
        <image class="modal-script-cover" src="{{item.cover}}" mode="aspectFill" />
        <view class="modal-script-info">
          <text class="modal-script-name">{{item.name}}</text>
          <view class="modal-script-tags">
            <text class="tag tag-type">{{item.type}}</text>
            <text class="tag tag-player">{{item.playerCount}}人</text>
          </view>
        </view>
        <view class="modal-check" wx:if="{{selectedScript.id === item.id}}">✓</view>
      </view>
    </scroll-view>
  </view>
</view>
