/* pages/script-list/script-list.wxss */
.script-list-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #fff;
  padding-top: calc(var(--status-bar-height) + var(--nav-bar-height));
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
}

.search-box {
  flex: 1;
  position: relative;
}

.search-input {
  width: 100%;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 80rpx 0 30rpx;
  color: #333;
  font-size: 26rpx;
}

.placeholder {
  color: #999;
}

.search-icon {
  position: absolute;
  right: 15rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 24rpx;
  background: #E8F5E9;
  border-radius: 35rpx;
  font-size: 26rpx;
  color: #4CAF50;
}

.filter-icon {
  font-size: 24rpx;
}

/* 类型标签 */
.type-tabs {
  white-space: nowrap;
  padding: 20rpx;
  background: #fff;
}

.type-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.type-tab.active {
  background: #4CAF50;
  color: #fff;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.sort-item {
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.sort-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #4CAF50;
  border-radius: 2rpx;
}

/* 剧本列表 */
.script-list {
  flex: 1;
  padding: 20rpx;
  background: #fff;
}

.script-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.script-cover {
  width: 180rpx;
  height: 240rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.script-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.script-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.script-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 8rpx;
}

.script-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.script-intro {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.script-meta {
  display: flex;
  justify-content: flex-start;
  align-items: center;
}

.meta-left {
  display: flex;
  gap: 16rpx;
}

.rating {
  font-size: 26rpx;
  color: #FF9800;
}

.play-count {
  font-size: 24rpx;
  color: #999;
}

.price {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF6B00;
  background: #FFF3E0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
  background: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background: #fff;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 筛选弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.filter-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  padding: 30rpx;
  z-index: 101;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.filter-tags {
  display: flex;
  gap: 16rpx;
  flex-wrap: nowrap;
  overflow-x: auto;
}

.filter-tag {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.filter-tag.active {
  background: #E8F5E9;
  color: #4CAF50;
  border-color: #4CAF50;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-reset,
.btn-confirm {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-reset {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
}
