<!--pages/script-list/script-list.wxml-->
<view class="script-list-container">
  <!-- 自定义导航栏 -->
  <custom-navbar city="" bindcitytap="" />

  <!-- 搜索和筛选 -->
  <view class="filter-bar">
    <view class="search-box">
      <input class="search-input" placeholder="搜索剧本名称..." placeholder-class="placeholder" bindinput="onSearchInput" value="{{searchKeyword}}" />
      <view class="search-icon">🔍</view>
    </view>
    <view class="filter-btn" bindtap="showFilterModal">
      <text>筛选</text>
      <text class="filter-icon">⚙️</text>
    </view>
  </view>

  <!-- 类型标签 -->
  <scroll-view class="type-tabs" scroll-x>
    <view class="type-tab {{activeType === 'all' ? 'active' : ''}}" bindtap="selectType" data-type="all">全部</view>
    <view class="type-tab {{activeType === item ? 'active' : ''}}" wx:for="{{types}}" wx:key="*this" bindtap="selectType" data-type="{{item}}">{{item}}</view>
  </scroll-view>

  <!-- 排序选项 -->
  <view class="sort-bar">
    <view class="sort-item {{activeSort === 'hot' ? 'active' : ''}}" bindtap="selectSort" data-sort="hot">热度</view>
    <view class="sort-item {{activeSort === 'rating' ? 'active' : ''}}" bindtap="selectSort" data-sort="rating">评分</view>
    <view class="sort-item {{activeSort === 'newest' ? 'active' : ''}}" bindtap="selectSort" data-sort="newest">最新</view>
    <view class="sort-item {{activeSort === 'players' ? 'active' : ''}}" bindtap="selectSort" data-sort="players">人数</view>
  </view>

  <!-- 剧本列表 -->
  <scroll-view class="script-list" scroll-y bindscrolltolower="loadMoreScripts" lower-threshold="100">
    <view class="script-item" wx:for="{{filteredScripts}}" wx:key="id" bindtap="viewScriptDetail" data-id="{{item.id}}">
      <image class="script-cover" src="{{item.cover}}" mode="aspectFill" />
      <view class="script-info">
        <text class="script-name">{{item.name}}</text>
        <text class="script-intro">{{item.intro}}</text>
        <view class="script-tags">
          <text class="tag tag-type">{{item.type}}</text>
          <text class="tag tag-difficulty">{{item.difficulty}}</text>
          <text class="tag tag-player">{{item.playerCount}}人</text>
          <text class="tag">{{item.duration}}h</text>
        </view>
        <view class="script-meta">
          <view class="meta-left">
            <text class="rating">⭐ {{item.rating}}</text>
            <text class="play-count">{{item.playCount}}人玩过</text>
          </view>
          <text class="price">{{item.isFree ? '免费' : item.price + '金币'}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text wx:if="{{loading}}">加载中...</text>
      <text wx:else>上拉加载更多</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore}}">
      <text>没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredScripts.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无剧本</text>
    </view>
  </scroll-view>
</view>

<!-- 筛选弹窗 -->
<view class="modal-mask" wx:if="{{showFilter}}" bindtap="hideFilterModal">
  <view class="filter-modal" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">筛选条件</text>
      <text class="modal-close" bindtap="hideFilterModal">✕</text>
    </view>

    <view class="filter-section">
      <text class="filter-title">难度</text>
      <view class="filter-tags">
        <view class="filter-tag {{!selectedDifficulty ? 'active' : ''}}" bindtap="selectDifficulty" data-difficulty="">全部</view>
        <view class="filter-tag {{selectedDifficulty === '简单' ? 'active' : ''}}" bindtap="selectDifficulty" data-difficulty="简单">简单</view>
        <view class="filter-tag {{selectedDifficulty === '中等' ? 'active' : ''}}" bindtap="selectDifficulty" data-difficulty="中等">中等</view>
        <view class="filter-tag {{selectedDifficulty === '困难' ? 'active' : ''}}" bindtap="selectDifficulty" data-difficulty="困难">困难</view>
      </view>
    </view>

    <view class="filter-section">
      <text class="filter-title">人数</text>
      <view class="filter-tags">
        <view class="filter-tag {{!selectedPlayerCount ? 'active' : ''}}" bindtap="selectPlayerCount" data-count="">全部</view>
        <view class="filter-tag {{selectedPlayerCount === '3-4' ? 'active' : ''}}" bindtap="selectPlayerCount" data-count="3-4">3-4人</view>
        <view class="filter-tag {{selectedPlayerCount === '5-6' ? 'active' : ''}}" bindtap="selectPlayerCount" data-count="5-6">5-6人</view>
        <view class="filter-tag {{selectedPlayerCount === '7+' ? 'active' : ''}}" bindtap="selectPlayerCount" data-count="7+">7人以上</view>
      </view>
    </view>

    <view class="filter-section">
      <text class="filter-title">价格</text>
      <view class="filter-tags">
        <view class="filter-tag {{priceType === 'all' ? 'active' : ''}}" bindtap="selectPriceType" data-type="all">全部</view>
        <view class="filter-tag {{priceType === 'free' ? 'active' : ''}}" bindtap="selectPriceType" data-type="free">免费</view>
        <view class="filter-tag {{priceType === 'paid' ? 'active' : ''}}" bindtap="selectPriceType" data-type="paid">付费</view>
      </view>
    </view>

    <view class="filter-actions">
      <button class="btn-reset" bindtap="resetFilter">重置</button>
      <button class="btn-confirm" bindtap="applyFilter">确定</button>
    </view>
  </view>
</view>
