/* 全局样式 - 清新白色主题 */
page {
  background-color: #f5f5f5;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  /* 导航栏高度变量 */
  --status-bar-height: 44px;
  --nav-bar-height: 44px;
}

/* 主题色 */
.theme-primary {
  color: #4CAF50;
}
.theme-secondary {
  color: #2196F3;
}
.theme-accent {
  color: #FF9800;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-secondary {
  background: #fff;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 输入框样式 */
.input {
  background: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #333;
  font-size: 28rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-difficulty {
  background: #FFF3E0;
  color: #FF9800;
}

.tag-type {
  background: #E3F2FD;
  color: #2196F3;
}

.tag-player {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 底部安全区 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
