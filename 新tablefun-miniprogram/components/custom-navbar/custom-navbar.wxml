<!--components/custom-navbar/custom-navbar.wxml-->
<view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
  <!-- 左侧返回键 -->
  <view class="nav-left" wx:if="{{showBack}}" bindtap="onBackTap">
    <text class="back-icon">‹</text>
  </view>

  <!-- 左侧城市选择 -->
  <view class="nav-left" wx:elif="{{city && city !== ''}}" bindtap="onCityTap">
    <text class="city-text">{{city}}</text>
    <text class="city-arrow" wx:if="{{showArrow}}">▼</text>
  </view>

  <!-- 左侧空占位 -->
  <view class="nav-left" wx:else></view>

  <!-- 中间标题 -->
  <view class="nav-center">
    <text class="nav-title">桌趣</text>
  </view>

  <!-- 右侧占位 -->
  <view class="nav-right"></view>
</view>
