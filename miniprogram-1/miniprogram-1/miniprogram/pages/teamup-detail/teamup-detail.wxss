page {
  background-color: #f8f9fa; /* 灰底衬托白卡片 */
}

.page-container {
  padding: 20rpx 30rpx;
}

/* 统一的卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

/* --- 1. 剧本卡片 --- */
.script-card {
  display: flex;
  align-items: center;
}
.cover {
  width: 140rpx;
  height: 190rpx;
  border-radius: 12rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}
.script-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}
.tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.tag {
  font-size: 22rpx;
  color: #666;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.subtitle {
  font-size: 24rpx;
  color: #999;
}

/* --- 2. 组局信息卡片 --- */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}
.info-row:last-child {
  margin-bottom: 0;
}
.label {
  color: #666;
  width: 140rpx;
  flex-shrink: 0;
}
.value {
  color: #333;
  flex: 1;
  text-align: right;
  font-weight: 500;
}
.value-with-icon {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
}
.icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}
.value.notes {
  text-align: left;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: -6rpx;
  font-weight: normal;
  line-height: 1.5;
}
/* 倒计时颜色 */
.counting-text { color: #ff9500; font-weight: bold; }
.locked-text { color: #999999; font-weight: bold; }

/* --- 3. 玩家卡片 --- */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.player-count {
  font-size: 28rpx;
  color: #999;
}
.player-count .current {
  color: #ff5a5f;
  font-weight: bold;
  font-size: 32rpx;
}
.avatar-list {
  display: flex;
  flex-wrap: wrap;
  gap: 30rpx 40rpx;
}
.avatar-item {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}
/* 新增：为头像和标签建立一个相对定位的盒子 */
.avatar-wrapper {
  position: relative; /* 核心：把“发起人”标签锁在这个盒子里 */
  width: 100rpx;      /* 和你的图片宽度保持一致 */
  height: 100rpx;
  display: flex;
  justify-content: center;
}

/* 优化后的发起人标签 */
.creator-badge {
  position: absolute;
  bottom: -12rpx;
  
  /* 增加这下面两行，确保标签永远在头像正中间 */
  left: 50%;
  transform: translateX(-50%); 
  
  background: #ff5a5f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  border: 2rpx solid #fff;
  z-index: 2;
}
.avatar-item.empty {
  border: 2rpx dashed #ccc;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #fafafa;
  box-sizing: border-box;
}
.empty-text {
  font-size: 22rpx;
  color: #bbb;
}

/* --- 底部按钮区 --- */
.bottom-space {
  height: 160rpx;
}
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #ffffff;
  padding: 20rpx 40rpx calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}
.btn-primary {
  background: #333333;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 90rpx;
  
  display: flex;
  align-items: center;
  justify-content: center;
  
  width: 100% !important;
  padding: 0;
}
.btn-outline {
  background: #ffffff;
  color: #333333;
  border: 2rpx solid #333333;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 90rpx; /* 稍微加高一点，更有质感 */
  
  /* 核心修复：移除 line-height，改为 Flex 居中 */
  display: flex;
  align-items: center;
  justify-content: center;
  
  width: 100% !important; /* 确保宽度撑满 */
  padding: 0; /* 移除默认内边距干扰 */
}
/* ===== 玩家昵称 ===== */
.player-name {
  font-size: 20rpx;
  color: #666;
  margin-top: 8rpx;
  max-width: 100rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 踢人按钮 ===== */
.kick-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #ff5a5f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
  box-shadow: 0 2rpx 6rpx rgba(255,90,95,0.4);
}

/* ===== 退出按钮用警告色区分 ===== */
.btn-quit {
  background: #ff5a5f !important;
}
