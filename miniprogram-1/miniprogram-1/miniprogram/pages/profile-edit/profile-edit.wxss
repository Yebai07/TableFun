page { background-color: #f8f9fa; }
.page-container { padding-bottom: 180rpx; }

/* 导航 */
/* 导航栏居中显示 */
.nav-bar { 
  display: flex; 
  justify-content: center; /* 核心修改：居中对齐 */
  align-items: center; 
  padding: 40rpx 30rpx 20rpx; 
  background: #fff; 
  margin-bottom: 30rpx; 
}
.nav-title { font-size: 34rpx; font-weight: bold; color: #333; }

/* 表单卡片 */
.form-group { background: #fff; margin: 0 30rpx 30rpx; border-radius: 24rpx; padding: 0 30rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02); }
.form-item { display: flex; justify-content: space-between; align-items: center; min-height: 110rpx; border-bottom: 1rpx solid #f5f5f5; }
.form-item:last-child { border-bottom: none; }
.form-item.disabled { opacity: 0.7; }
.label { font-size: 30rpx; color: #333; font-weight: 500; flex-shrink: 0; margin-right: 40rpx; }

.right-content { display: flex; align-items: center; }
.avatar-preview { width: 70rpx; height: 70rpx; border-radius: 50%; }
.arrow { color: #ccc; margin-left: 16rpx; }

.input-control { flex: 1; text-align: right; font-size: 30rpx; color: #333; }
.radio-group { display: flex; gap: 30rpx; }
.radio-label { font-size: 30rpx; color: #333; display: flex; align-items: center; gap: 8rpx;}

/* 块状表单项 */
.form-item-column { padding: 30rpx 0; display: flex; flex-direction: column; }
.textarea-control { width: 100%; height: 120rpx; margin-top: 20rpx; font-size: 28rpx; background: #f8f9fa; padding: 20rpx; border-radius: 12rpx; box-sizing: border-box; }

/* 标签池 */
.tag-pool { display: flex; flex-wrap: wrap; gap: 20rpx; margin-top: 30rpx; }
.tag-chip { padding: 12rpx 30rpx; background: #f5f5f5; color: #666; border-radius: 40rpx; font-size: 26rpx; transition: all 0.2s; border: 2rpx solid transparent; }
.tag-chip.active { background: #fffbe6; color: #d48806; border-color: #ffe58f; font-weight: bold; }

.custom-tag-box { display: flex; margin-top: 30rpx; gap: 20rpx; }
.custom-input { flex: 1; height: 70rpx; background: #f8f9fa; border-radius: 35rpx; padding: 0 30rpx; font-size: 26rpx; }
.btn-add-tag { margin: 0; width: 140rpx; height: 70rpx; line-height: 70rpx; background: #333; color: #fff; font-size: 26rpx; border-radius: 35rpx; padding: 0;}

/* 底部保存 */
.footer-bar { position: fixed; bottom: 0; width: 100%; padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom)); box-sizing: border-box; background: #fff; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); z-index: 100;}
.btn-save { background: #333; color: #fff; border-radius: 50rpx; font-size: 32rpx; font-weight: bold; height: 90rpx; line-height: 90rpx; width: 100% !important;}