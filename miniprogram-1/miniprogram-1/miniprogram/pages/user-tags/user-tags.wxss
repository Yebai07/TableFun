/* pages/user-tags/user-tags.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e6f7ff 100%);
  padding-bottom: 30rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.back-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.back-arrow {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-right {
  width: 60rpx;
}

/* 头部信息 */
.header-container {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.avatar-container {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

/* 标签部分 */
.tags-section {
  background-color: rgba(255, 255, 255, 0.8);
  margin: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

/* 标签样式 */
.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 15rpx 30rpx;
  border-radius: 30rpx;
  border: 2rpx solid;
  font-size: 24rpx;
  color: #333;
  background-color: #f5f5f5;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.tag-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.tag-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.tag-item:active::before {
  left: 100%;
}

.tag-text {
  margin-right: 8rpx;
}

.tag-count {
  font-size: 20rpx;
  color: #666;
}

/* 标签颜色 */
.tag-orange {
  border-color: #ff9800;
}

.tag-red {
  border-color: #f44336;
}

.tag-purple {
  border-color: #9c27b0;
}

.tag-blue {
  border-color: #2196f3;
}

.tag-green {
  border-color: #4caf50;
}

.tag-gray {
  border-color: #9e9e9e;
}