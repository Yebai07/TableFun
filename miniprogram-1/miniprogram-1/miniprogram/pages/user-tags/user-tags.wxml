<!--pages/user-tags/user-tags.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="navigateBack">
      <text class="back-arrow">←</text>
    </view>
    <view class="nav-title">TA的标签</view>
    <view class="nav-right"></view>
  </view>
  
  <!-- 头部信息 -->
  <view class="header-container">
    <view class="avatar-container">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname}}</text>
      <text class="user-id">ID: {{userInfo._id.substring(0, 6)}}</text>
    </view>
  </view>
  
  <!-- TA眼中的自己 -->
  <view class="tags-section">
    <text class="section-title">TA眼中的自己</text>
    <view class="tags-container">
      <block wx:for="{{userInfo.tags_self}}" wx:key="index">
        <view class="tag-item" wx:class="{{getSelfTagClass(item)}}">
          <text class="tag-text">{{item}}</text>
        </view>
      </block>
    </view>
  </view>
  
  <!-- 别人眼中的TA -->
  <view class="tags-section">
    <text class="section-title">别人眼中的TA</text>
    <view class="tags-container">
      <block wx:for="{{userInfo.tags_others}}" wx:key="index">
        <view class="tag-item" wx:class="{{getOtherTagClass(item.name)}}">
          <text class="tag-text">{{item.name}}</text>
          <text class="tag-count">×{{item.count}}</text>
        </view>
      </block>
    </view>
  </view>
</view>