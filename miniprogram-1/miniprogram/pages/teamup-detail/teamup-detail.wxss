page { background-color: #f8f9fa; }
.page-container { padding: 20rpx; }

/* 剧本卡片 */
.script-card { display: flex; background: #fff; padding: 30rpx; border-radius: 20rpx; margin-bottom: 30rpx; }
.cover { width: 140rpx; height: 180rpx; border-radius: 12rpx; background: #eee; flex-shrink: 0; }
.info { margin-left: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.title { font-size: 34rpx; font-weight: bold; color: #333; }
.time, .lock, .notes { font-size: 26rpx; color: #666; margin-top: 10rpx;}
.lock { color: #f5a623; }

/* 玩家坑位 */
.players-section { background: #fff; padding: 30rpx; border-radius: 20rpx; }
.section-header { display: flex; justify-content: space-between; margin-bottom: 30rpx; }
.section-header .title { font-size: 30rpx; font-weight: bold; }
.section-header .count { font-size: 28rpx; color: #ff5a5f; font-weight: bold; }

.avatar-grid { display: flex; flex-wrap: wrap; gap: 20rpx; }
.player-slot { width: 100rpx; height: 100rpx; border-radius: 50%; position: relative; }
.player-slot.filled .avatar { width: 100%; height: 100%; border-radius: 50%; border: 4rpx solid #fff; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1); }
.creator-badge { position: absolute; bottom: -10rpx; left: 50%; transform: translateX(-50%); background: #ff5a5f; color: #fff; font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 20rpx; white-space: nowrap; }
.player-slot.empty { background: #f0f0f0; display: flex; justify-content: center; align-items: center; border: 2rpx dashed #ccc; }
.empty-text { font-size: 20rpx; color: #999; }

/* 底部按钮 */
.bottom-space { height: 160rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; width: 100%; background: #fff; padding: 20rpx 30rpx; box-sizing: border-box; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05); }
button { border-radius: 50rpx; font-size: 32rpx; font-weight: bold; width: 100%; padding: 24rpx 0; line-height: 1.5; }
.btn-primary { background: #333; color: #fff; }
.btn-quit { background: #fff; color: #333; border: 2rpx solid #333; }
.btn-disabled { background: #eee; color: #999; }