page { background-color: #f8f9fa; }

/* 统一吸顶容器 */
.sticky-header { position: sticky; top: 0; z-index: 100; background-color: #f8f9fa; padding-top: 20rpx; }

/* 搜索栏样式 */
.search-box { display: flex; align-items: center; background: #ffffff; margin: 0 20rpx 20rpx; height: 72rpx; padding: 0 30rpx; border-radius: 36rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03); }
.search-input { flex: 1; font-size: 28rpx; margin-left: 16rpx; color: #333; }

/* 筛选栏样式 */
.filter-bar { display: flex; background: #ffffff; padding: 24rpx 40rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03); margin-bottom: 24rpx; }
.filter-item { display: flex; align-items: center; margin-right: 60rpx; }
.filter-text { font-size: 28rpx; color: #333; font-weight: 500; }
.icon-triangle { font-size: 20rpx; color: #999; margin-left: 8rpx; }
.icon-sort { font-size: 24rpx; color: #0c0c0c; margin-left: 8rpx; font-weight: bold; }

/* 列表容器留白 */
.page-container { padding: 0 0 20rpx; }
.teamup-list { padding: 0 20rpx; }

/* 卡片整体与头部 */
.loading-state, .empty-state { text-align: center; padding: 150rpx 0; color: #999; font-size: 28rpx; line-height: 1.6; }
.teamup-card { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.card-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f0f0f0; padding-bottom: 20rpx; margin-bottom: 20rpx; }
.time-text { font-size: 30rpx; font-weight: bold; color: #ff5a5f; }
/* 只有处于已锁定状态才显示的标签 */
.status-tag.locked { 
  font-size: 24rpx; 
  color: #e53935; /* 警告红 */
  background: rgba(229, 57, 53, 0.1); 
  padding: 4rpx 16rpx; 
  border-radius: 8rpx; 
  border: 1rpx solid #e53935;
  font-weight: bold;
}

/* 剧本信息区 */
.script-info { display: flex; margin-bottom: 20rpx; }
.script-cover { width: 120rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; background: #eee; }
.script-text { margin-left: 20rpx; flex: 1; display: flex; flex-direction: column; justify-content: center; } /* 改为垂直居中，因为去掉了备注，内容变少了 */
.script-title { font-size: 32rpx; font-weight: bold; color: #333; }

/* 标签样式 */
.script-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin: 16rpx 0; }
.tag-type, .tag-players { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 8rpx; font-weight: 500; }
.tag-type { background: rgba(91, 134, 229, 0.1); color: #5b86e5; }
.tag-players { background: rgba(255, 90, 95, 0.1); color: #ff5a5f; }

.lock-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}
/* 还在倒计时：柔和的蓝色或橙色 */
.lock-status.counting {
  background: rgba(255, 149, 0, 0.1);
  color: #ff9500;
}

/* 底部操作区 */
.card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 20rpx; border-top: 1rpx dashed #f0f0f0; }
.player-count { font-size: 28rpx; color: #666; }
.count-highlight { font-size: 36rpx; font-weight: bold; color: #333; }
.count-total { font-size: 28rpx; }
.btn-join { margin: 0; padding: 0 40rpx; height: 64rpx; line-height: 64rpx; background: #333; color: #fff; font-size: 28rpx; border-radius: 32rpx; font-weight: bold; }
/* 点击反馈 */
.btn-join:active{
  transform: scale(0.96); /* 按下去有个微小的缩放效果，手感更好 */
  opacity: 0.9;
}
