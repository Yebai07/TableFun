page { background-color: #f8f9fa; }

/* 统一吸顶容器 */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #f8f9fa; /* 与页面底色一致，防穿透 */
  padding-top: 20rpx;
}

/* 搜索栏样式 */
.search-box {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: 0 20rpx 20rpx;
  height: 72rpx;
  padding: 0 30rpx;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 16rpx;
  color: #333;
}

/* 筛选栏样式调整（移除单独的吸顶属性） */
.filter-bar {
  display: flex;
  background: #ffffff;
  padding: 24rpx 40rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
  margin-bottom: 24rpx;
}

.filter-item { display: flex; align-items: center; margin-right: 60rpx; }
.filter-text { font-size: 28rpx; color: #333; font-weight: 500; }
.icon-triangle { font-size: 20rpx; color: #999; margin-left: 8rpx; }
.icon-sort { font-size: 24rpx; color: #080808; margin-left: 8rpx; font-weight: bold; }

/* 列表容器留白 */
.page-container { padding: 0 0 20rpx; } /* 左右边距交给内部元素 */
.teamup-list { padding: 0 20rpx; }

/* ========================================= */
/* 下方保留你原有的 .loading-state, .teamup-card 等所有卡片样式 */

/* 以下为原有的卡片样式（保持不变） */
.loading-state, .empty-state { text-align: center; padding: 150rpx 0; color: #999; font-size: 28rpx; line-height: 1.6; }
.teamup-card { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.card-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f0f0f0; padding-bottom: 20rpx; margin-bottom: 20rpx; }
.time-text { font-size: 30rpx; font-weight: bold; color: #ff5a5f; }
.status-tag { font-size: 24rpx; color: #fff; background: #ff5a5f; padding: 4rpx 16rpx; border-radius: 8rpx; }
.script-info { display: flex; margin-bottom: 20rpx; }
.script-cover { width: 120rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; background: #eee; }
.script-text { margin-left: 20rpx; flex: 1; display: flex; flex-direction: column; justify-content: space-around; }
.script-title { font-size: 32rpx; font-weight: bold; color: #333; }
.lock-rule { font-size: 24rpx; color: #f5a623; }
.notes { font-size: 24rpx; color: #888; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 20rpx; border-top: 1rpx dashed #f0f0f0; }
.player-count { font-size: 28rpx; color: #666; }
.count-highlight { font-size: 36rpx; font-weight: bold; color: #333; }
.count-total { font-size: 28rpx; }
.btn-join { margin: 0; padding: 0 40rpx; height: 64rpx; line-height: 64rpx; background: #333; color: #fff; font-size: 28rpx; border-radius: 32rpx; font-weight: bold; }