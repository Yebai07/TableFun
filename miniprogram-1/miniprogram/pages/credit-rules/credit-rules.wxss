/* pages/credit-rules/credit-rules.wxss */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 规则列表 */
.rules-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.rule-icon.positive {
  background-color: #f6ffed;
  color: #52c41a;
}

.rule-icon.negative {
  background-color: #fff1f0;
  color: #ff4d4f;
}

.rule-icon.warning {
  background-color: #fffbe6;
  color: #faad14;
}

.rule-icon text {
  font-size: 32rpx;
  font-weight: bold;
}

.rule-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rule-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.rule-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.rule-score {
  font-size: 32rpx;
  font-weight: bold;
}

.rule-score.positive {
  color: #52c41a;
}

.rule-score.negative {
  color: #ff4d4f;
}

.rule-score.warning {
  color: #faad14;
  font-size: 26rpx;
}

.rule-desc {
  font-size: 26rpx;
  color: #999;
}

/* 提示区域 */
.tips-section {
  background-color: #e6f7ff;
  border-radius: 16rpx;
  padding: 30rpx;
  border-left: 6rpx solid #1890ff;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 16rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
