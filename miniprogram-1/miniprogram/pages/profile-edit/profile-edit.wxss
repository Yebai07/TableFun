/* pages/profile-edit/profile-edit.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e6f7ff 100%);
  padding-bottom: 30rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.back-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.back-arrow {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.save-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.save-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.save-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 表单容器 */
.form-container {
  padding: 30rpx;
  margin-top: 20rpx;
}

/* 表单项 */
.form-item {
  background-color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  border-radius: 15rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

/* 头像选择 */
.avatar-container {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-upload {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  text-align: center;
  padding: 10rpx;
  font-size: 20rpx;
}

.upload-text {
  color: #fff;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  background-color: #f9f9f9;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 120rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 24rpx;
  background-color: #f9f9f9;
  resize: none;
}

/* 性别选择 */
.gender-container {
  display: flex;
  gap: 40rpx;
}

.gender-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #333;
}

/* 标签选择 */
.tag-container {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-top: 10rpx;
}

.tag-item {
  padding: 15rpx 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.tag-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.tag-selected {
  border-color: #ff6b35;
  background-color: #ff6b35;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  transform: translateY(-2rpx);
}

.tag-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s;
}

.tag-item:active::before {
  left: 100%;
}

/* 自定义标签 */
.custom-tag-section {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.custom-tag-label {
  display: block;
  font-size: 22rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 15rpx;
}

.custom-tag-input-container {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.custom-tag-input {
  flex: 1;
  height: 60rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 30rpx;
  padding: 0 25rpx;
  font-size: 24rpx;
  background-color: #f9f9f9;
}

.add-tag-btn {
  padding: 0 30rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: #ff6b35;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.3);
}

.add-tag-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}