.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.section-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 30rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 16rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #cccccc;
}

/* 标签网格 */
.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx; /* 控制标签间距 */
}

/* 基础胶囊标签 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 36rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 500;
  background-color: #f5f5f5;
  color: #666666;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2rpx solid transparent;
}

/* 选中状态：酷炫黑 */
.tag-selected {
  background-color: #333333;
  color: #ffffff;
  transform: scale(1.05); /* 选中时略微放大，手感极佳 */
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.15);
}

/* 自定义输入框 */
.custom-input-box {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.input-field {
  flex: 1;
  background: #f5f5f5;
  height: 88rpx;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
}

.btn-add {
  margin: 0 !important;
  width: 160rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  background: #eeeeee;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 0;
}
.btn-add:active { background: #e0e0e0; }

/* 底部操作区 */
.bottom-action {
  margin-top: 80rpx;
}

.btn-primary {
  background: #333333;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  width: 100% !important;
  padding: 24rpx 0;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}
.btn-primary:active { transform: scale(0.98); opacity: 0.9; }