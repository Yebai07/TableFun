<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back-button" bindtap="navigateBack">
      <text class="back-icon">←</text>
    </view>
    <view class="title">评价TA</view>
  </view>

  <!-- 标签选择区域 -->
  <view class="section">
    <text class="section-title">选择标签</text>
    <view class="tags-container">
      <view 
        wx:for="{{processedTags}}" 
        wx:key="index"
        class="tag {{item.selected ? 'tag-selected' : ''}}"
        data-index="{{index}}"
        bindtap="toggleTag"
      >
        <text class="tag-text">{{item.name}}</text>
        <text wx:if="{{item.selected}}" class="tag-check">✓</text>
      </view>
    </view>
  </view>

  <!-- 自定义标签 -->
  <view class="section">
    <text class="section-title">自定义标签</text>
    <view class="custom-tag-container">
      <input 
        class="custom-tag-input" 
        placeholder="输入自定义标签" 
        value="{{customTag}}"
        bindinput="onCustomTagInput"
      />
      <button class="add-button" bindtap="addCustomTag">添加</button>
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="submit-button" bindtap="submitEvaluation">提交评价</button>
</view>
