<view class="page-container">
  <view wx:if="{{isLoading}}" class="loading-state">
    <text>加载中...</text>
  </view>
  
  <view wx:elif="{{!isRegistered}}" class="unregistered-container">
    <image class="unregistered-avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
    <text class="unregistered-title">探索桌游新世界</text>
    <text class="unregistered-subtext">一键注册，开启你的剧本杀拼车之旅</text>
    <button class="btn-primary" bindtap="navigateToRegister">立即加入</button>
  </view>
  
  <view wx:else class="profile-content">
    
    <view class="header-section">
      <view class="nav-bar">
        <view class="settings-btn" bindtap="navigateToSettings">
          <text class="settings-icon">⚙️</text>
        </view>
      </view>

      <view class="user-info-row">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" catchtap="chooseAvatar"></image>
        
        <view class="info-text" bindtap="navigateToUserCard">
          <text class="nickname">{{userInfo.nickname || '玩家'}}</text>
          <text class="user-id">ID: {{userInfo.displayId || userInfo._id || ''}}</text>
          <text class="user-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
        </view>
        
        <text class="arrow-right">></text>
      </view>
    </view>

    <view class="stats-card">
      <view class="stat-item" bindtap="navigateToUserTags">
        <text class="stat-num">{{userInfo.creditScore || 800}}</text>
        <text class="stat-label">信用分</text>
      </view>
      <view class="divider"></view>
      <view class="stat-item" bindtap="navigateToUserTags">
        <text class="stat-num">{{userInfo.tags_self && userInfo.tags_self.length || 0}}</text>
        <text class="stat-label">我的标签</text>
      </view>
      <view class="divider"></view>
      <view class="stat-item">
        <text class="stat-num">0</text>
        <text class="stat-label">动态</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="viewParticipatedScripts">
        <view class="menu-left">
          <text class="menu-icon">📅</text>
          <text class="menu-text">我的行程</text>
        </view>
        <text class="arrow-right">></text>
      </view>
      <view class="menu-item" bindtap="viewMedals">
        <view class="menu-left">
          <text class="menu-icon">🏅</text>
          <text class="menu-text">我的勋章</text>
        </view>
        <text class="arrow-right">></text>
      </view>
    </view>

    <view class="action-section">
      <button class="btn-outline" bindtap="navigateToProfileEdit">编辑个人资料</button>
    </view>

  </view>
</view>