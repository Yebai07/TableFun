/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e6f7ff 100%);
}

/* 加载中 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading {
  font-size: 28rpx;
  color: #999;
}

/* 未注册状态 */
.unregistered-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx;
}

.unregistered-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.unregistered-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 40rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.unregistered-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.unregistered-subtext {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.register-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 25rpx 80rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
}

.register-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 已注册状态 - 个人主页内容 */
.profile-content {
  padding: 20rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.settings-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.8);
  margin-left: auto;
}

.settings-btn:active {
  background-color: rgba(0, 0, 0, 0.05);
}

.settings-icon {
  font-size: 32rpx;
}

/* 头像和基本信息 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.avatar-container {
  margin-bottom: 30rpx;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nickname {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.user-id {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.user-bio {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  padding: 0 20rpx;
}

/* 数据统计行 */
.stats-container {
  display: flex;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item:active {
  opacity: 0.7;
}

.stat-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx dashed #ddd;
  background-color: rgba(255, 255, 255, 0.5);
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 功能入口按钮 */
.feature-container {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.feature-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 40rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-item:active {
  background-color: rgba(0, 0, 0, 0.03);
}

.feature-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.feature-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 编辑资料按钮 */
.edit-profile-section {
  padding: 20rpx 0;
}

.edit-profile-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 30rpx 0;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
}

.edit-profile-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}
