page { background-color: #f8f9fa; }
.page-container { min-height: 100vh; }

/* 加载与未注册状态 */
.loading-state { text-align: center; padding-top: 40vh; color: #999; }
.unregistered-container { display: flex; flex-direction: column; align-items: center; padding-top: 20vh; }
.unregistered-avatar { width: 180rpx; height: 180rpx; border-radius: 50%; margin-bottom: 40rpx; opacity: 0.8; }
.unregistered-title { font-size: 40rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.unregistered-subtext { font-size: 28rpx; color: #888; margin-bottom: 60rpx; }

/* 按钮通用样式 */
.btn-primary { background: #333; color: #fff; border-radius: 50rpx; font-size: 32rpx; font-weight: bold; width: 80% !important; padding: 24rpx 0; }
.btn-outline { background: transparent; color: #333; border-radius: 50rpx; font-size: 30rpx; font-weight: bold; width: 100% !important; padding: 24rpx 0; border: 2rpx solid #e0e0e0; }

/* 顶部深色头部 */
.header-section { background: #2c2c2c; padding: 60rpx 40rpx 100rpx; border-radius: 0 0 40rpx 40rpx; }
.nav-bar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 15rpx; }
.settings-icon { font-size: 40rpx; }

.user-info-row { display: flex; align-items: center; }
.avatar { width: 130rpx; height: 130rpx; border-radius: 50%; border: 4rpx solid rgba(255, 255, 255, 0.2); flex-shrink: 0; }
.info-text { margin-left: 30rpx; flex: 1; display: flex; flex-direction: column; }
.nickname { font-size: 40rpx; font-weight: bold; color: #fff; margin-bottom: 8rpx; }
.user-id, .user-bio { font-size: 24rpx; color: rgba(255, 255, 255, 0.7); }
.user-bio { margin-top: 8rpx; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 1; overflow: hidden; }

/* 悬浮数据卡片 (核心优化) */
.stats-card { background: #fff; margin: -60rpx 30rpx 40rpx; padding: 40rpx 0; border-radius: 24rpx; display: flex; align-items: center; box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.05); position: relative; z-index: 10; }
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 8rpx; }
.stat-label { font-size: 24rpx; color: #888; }
.divider { width: 2rpx; height: 60rpx; background: #f0f0f0; }

/* 菜单组 */
.menu-group { background: #fff; margin: 0 30rpx 60rpx; border-radius: 24rpx; padding: 10rpx 30rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-left { display: flex; align-items: center; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text { font-size: 30rpx; color: #333; font-weight: 500; }

.arrow-right { font-size: 28rpx; color: #ccc; }

.action-section { padding: 0 40rpx 40rpx; }
/* ================= 头像选择弹窗样式 ================= */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  z-index: 900;
  backdrop-filter: blur(4rpx); /* 给背景一点高级的模糊感 */
}

.avatar-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  z-index: 999;
  animation: slideUp 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* 丝滑的弹出动画 */
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.close-btn {
  font-size: 44rpx;
  color: #999999;
  padding: 0 20rpx;
  margin-right: -20rpx;
}

/* 4列网格排版 */
.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx 20rpx;
  justify-items: center;
}

.avatar-option {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid transparent;
  transition: all 0.2s ease;
  background: #f5f5f5; /* 没图片时的底色 */
}

.avatar-option image {
  width: 100%;
  height: 100%;
}

/* 被选中的头像样式 */
.avatar-option.selected {
  border-color: #333333; /* 酷炫的纯黑描边 */
  transform: scale(1.08); /* 选中后稍微放大凸显 */
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1);
}

.avatar-option:active {
  transform: scale(0.95);
  opacity: 0.8;
}