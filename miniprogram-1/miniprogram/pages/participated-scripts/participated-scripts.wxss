.container {
  padding: 20rpx;
}
.nav-bar {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-title {
  font-size: 32rpx;
  font-weight: bold;
}
.loading-container, .empty-container {
  padding: 40rpx;
  align-items: center;
  justify-content: center;
}
.script-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}
.script-title {
  font-size: 30rpx;
}
.script-meta {
  color: #888;
  font-size: 24rpx;
}

