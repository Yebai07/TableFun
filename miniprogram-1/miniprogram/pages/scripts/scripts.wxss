page {
  background-color: #f8f9fa;
}

.page-container {
  padding: 20rpx;
}

.loading-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.script-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.cover-img {
  width: 160rpx;
  height: 220rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #eee; /* 图片未加载时的底色 */
}

.info-box {
  margin-left: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #5b86e5;
  background: rgba(91, 134, 229, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 10rpx;
}

.desc {
  font-size: 24rpx;
  color: #888;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2; /* 简介最多显示两行 */
  overflow: hidden;
  margin-right: 20rpx;
}

.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff5a5f;
  flex-shrink: 0;
}