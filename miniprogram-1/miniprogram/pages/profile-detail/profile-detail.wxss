.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 50rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-button {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: #333333;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.settings-button {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  font-size: 32rpx;
  color: #333333;
}

/* 个人信息区域 */
.info-section {
  background-color: #ffffff;
  padding: 40rpx 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.avatar-container {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 auto 20rpx;
  border: 4rpx solid #ff9800;
}

.avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 15rpx;
}

.user-bio {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  max-width: 80%;
  margin: 0 auto;
}

/* 数据统计 */
.stats-section {
  background-color: #ffffff;
  padding: 30rpx 20rpx;
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-divider {
  width: 1rpx;
  background-color: #e0e0e0;
  margin: 0 20rpx;
}

/* 功能入口 */
.features-section {
  background-color: #ffffff;
  margin-bottom: 20rpx;
}

.feature-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-text {
  font-size: 28rpx;
  color: #333333;
}

.feature-arrow {
  font-size: 24rpx;
  color: #999999;
}

/* 底部操作栏 */
.action-section {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx;
  margin-top: 40rpx;
}

.action-button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.evaluate-button {
  background-color: #ff9800;
  color: white;
}

.chat-button {
  background-color: #e3f2fd;
  color: #2196f3;
  border: 2rpx solid #2196f3;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .avatar-container {
    width: 140rpx;
    height: 140rpx;
  }
  
  .nickname {
    font-size: 28rpx;
  }
  
  .stat-number {
    font-size: 28rpx;
  }
  
  .feature-text {
    font-size: 26rpx;
  }
  
  .action-button {
    height: 72rpx;
    line-height: 72rpx;
    font-size: 26rpx;
  }
}
