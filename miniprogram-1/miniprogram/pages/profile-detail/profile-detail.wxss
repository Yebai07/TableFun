page { background-color: #f8f9fa; }
.page-container { padding-bottom: 160rpx; }

/* 头部视觉 */
.header-bg {
  background: linear-gradient(180deg, #2c2c2c 0%, #3d3d3d 100%);
  padding: 80rpx 0 140rpx;
  display: flex;
  justify-content: center;
  border-radius: 0 0 60rpx 60rpx;
}
.user-main { display: flex; flex-direction: column; align-items: center; }

.avatar-wrapper { position: relative; margin-bottom: 20rpx; }
.avatar { width: 170rpx; height: 170rpx; border-radius: 50%; border: 6rpx solid rgba(255, 255, 255, 0.15); box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.2); }
.gender-tag {
  position: absolute; bottom: 10rpx; right: 0; width: 44rpx; height: 44rpx;
  border-radius: 50%; color: #fff; font-size: 24rpx; display: flex;
  align-items: center; justify-content: center; border: 4rpx solid #3d3d3d;
}
.gender-tag.male { background: #5b86e5; }
.gender-tag.female { background: #ff5a5f; }

.nickname { font-size: 42rpx; font-weight: bold; color: #ffffff; }
.mbti-badge {
  background: rgba(255, 255, 255, 0.15); color: #ffd700; font-size: 22rpx;
  padding: 4rpx 20rpx; border-radius: 20rpx; margin-top: 12rpx; border: 1rpx solid rgba(255,215,0,0.3);
}

/* 悬浮指标 */
.stats-card {
  background: #fff; margin: -70rpx 40rpx 40rpx; padding: 40rpx 0;
  border-radius: 32rpx; display: flex; align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05); position: relative; z-index: 10;
}
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.num { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.label { font-size: 24rpx; color: #999; }
.divider { width: 2rpx; height: 50rpx; background: #f0f0f0; }

/* 资料分组 */
.detail-group { margin: 0 30rpx 40rpx; }
.section-title { font-size: 28rpx; color: #999; margin-left: 10rpx; margin-bottom: 16rpx; font-weight: 500; }

.info-list, .menu-list { background: #fff; border-radius: 24rpx; padding: 10rpx 30rpx; }
.info-item, .menu-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 30rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.info-item:last-child, .menu-item:last-child { border-bottom: none; }

.info-label { font-size: 30rpx; color: #666; }
.info-value { font-size: 30rpx; color: #333; font-weight: 500; }
.bio-text { color: #888; font-weight: normal; max-width: 400rpx; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.menu-left { display: flex; align-items: center; }
.menu-icon { font-size: 34rpx; margin-right: 20rpx; }
.menu-text { font-size: 30rpx; color: #333; }
.arrow { color: #ccc; font-size: 28rpx; }

/* 底部按钮 */
.footer-actions {
  position: fixed; bottom: 0; left: 0; width: 100%; padding: 30rpx 40rpx;
  box-sizing: border-box; background: #fff;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  display: flex;
  gap: 20rpx;
}
.btn-evaluate {
  background: #ffd700; color: #333; border-radius: 50rpx; font-size: 32rpx;
  font-weight: bold; padding: 24rpx 0; flex: 1 !important;
}
.btn-edit {
  background: #333; color: #fff; border-radius: 50rpx; font-size: 32rpx;
  font-weight: bold; padding: 24rpx 0; flex: 1 !important;
}