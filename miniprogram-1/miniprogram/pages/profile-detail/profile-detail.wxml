<view class="page-container" wx:if="{{userInfo}}">
  <view class="header-bg">
    <view class="user-main">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="gender-tag {{userInfo.gender == 1 ? 'male' : 'female'}}">
          {{userInfo.gender == 1 ? '♂' : '♀'}}
        </view>
      </view>
      <text class="nickname">{{userInfo.nickname || '玩家'}}</text>
      <view class="mbti-badge" wx:if="{{userInfo.mbti}}">{{userInfo.mbti}}</view>
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <text class="num">{{userInfo.creditScore || 800}}</text>
      <text class="label">信用分</text>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="num">{{userInfo.tags_self.length || 0}}</text>
      <text class="label">获得标签</text>
    </view>
    <view class="divider"></view>
    <view class="stat-item">
      <text class="num">{{dynamicCount || 0}}</text>
      <text class="label">动态</text>
    </view>
  </view>

  <view class="detail-group">
    <view class="section-title">基本信息</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">用户 ID</text>
        <text class="info-value">{{userInfo.displayId || userInfo._id}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">个性签名</text>
        <text class="info-value bio-text">{{userInfo.bio || '暂无签名'}}</text>
      </view>
    </view>
  </view>

  <view class="detail-group">
    <view class="section-title">我的成就</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="viewParticipatedScripts">
        <view class="menu-left">
          <text class="menu-icon">📜</text>
          <text class="menu-text">历史拼车行程</text>
        </view>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="viewMedals">
        <view class="menu-left">
          <text class="menu-icon">🏆</text>
          <text class="menu-text">荣誉勋章</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <view class="footer-actions">
    <button class="btn-evaluate" bindtap="navigateToRateUser">评价TA</button>
    <button class="btn-edit" bindtap="navigateToProfileEdit">修改资料</button>
  </view>
</view>