page { background-color: #f8f9fa; }
.page-container { padding-bottom: 60rpx; }

/* 导航栏 */
.nav-bar { 
  display: flex; 
  justify-content: center; /* 居中显示标题 */
  align-items: center; 
  padding: 40rpx 30rpx 20rpx; 
  background: #fff; 
  margin-bottom: 20rpx; 
}
.back-btn { padding: 10rpx; }
.back-arrow { font-size: 36rpx; color: #333; font-weight: bold; }
.nav-title { font-size: 34rpx; font-weight: bold; color: #333; }
.nav-right { width: 50rpx; } /* 占位平衡居中 */

/* 设置组卡片 */
.settings-group { background: #fff; margin: 0 30rpx 30rpx; border-radius: 24rpx; padding: 0 30rpx; }
.settings-item { display: flex; justify-content: space-between; align-items: center; padding: 36rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.settings-item:last-child { border-bottom: none; }
.settings-label { font-size: 30rpx; color: #333; }
.settings-arrow { font-size: 28rpx; color: #ccc; }

/* 退出按钮 */
.logout-container { margin-top: 60rpx; padding: 0 30rpx; }
.logout-btn { background: #fff; color: #ff5a5f; border-radius: 50rpx; font-size: 32rpx; font-weight: bold; width: 100% !important; padding: 24rpx 0; border: 2rpx solid #fff; }
.logout-btn:active { background: #fcfcfc; border-color: #ff5a5f; }