page { background-color: #f8f9fa; }

/* 顶部视觉设计 */
.header-bg {
  background: linear-gradient(180deg, #2c2c2c 0%, #3d3d3d 100%);
  padding: 80rpx 0 120rpx;
  display: flex;
  justify-content: center;
  border-radius: 0 0 60rpx 60rpx;
}
.user-main { display: flex; flex-direction: column; align-items: center; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 50%; border: 6rpx solid rgba(255, 255, 255, 0.15); box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.2); }
.nickname { font-size: 42rpx; font-weight: bold; color: #ffffff; margin-top: 24rpx; }
.id-badge { font-size: 22rpx; color: rgba(255,255,255,0.6); background: rgba(255,255,255,0.1); padding: 4rpx 20rpx; border-radius: 20rpx; margin-top: 12rpx; }

/* 指标卡片 */
.stats-card {
  background: #fff;
  margin: -60rpx 40rpx 40rpx;
  padding: 40rpx 0;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.05);
  position: relative;
  z-index: 10;
}
.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.num { font-size: 36rpx; font-weight: bold; color: #333; margin-bottom: 6rpx; }
.label { font-size: 24rpx; color: #999; }
.divider { width: 2rpx; height: 50rpx; background: #f0f0f0; }

/* 标签样式 */
.content-section { padding: 0 40rpx 160rpx; }
.tag-group { margin-bottom: 50rpx; }
.group-header { display: flex; align-items: center; margin-bottom: 24rpx; }
.group-title { font-size: 30rpx; font-weight: bold; color: #333; margin-right: 20rpx; flex-shrink: 0; }
.title-line { flex: 1; height: 2rpx; background: linear-gradient(90deg, #eee 0%, transparent 100%); }

.tag-list { display: flex; flex-wrap: wrap; gap: 16rpx; }

/* 自我标签：柔和彩色 */
.self-tag {
  padding: 10rpx 28rpx; border-radius: 40rpx; font-size: 24rpx; font-weight: 500;
  background: #f0f4ff; color: #5b86e5; border: 1rpx solid rgba(91, 134, 229, 0.2);
}
.full-width {
  width: 100% !important;
}
/* 别人评价：呼吸感设计 */
.tag-pill-other {
  display: flex; align-items: center; background: #fff;
  padding: 10rpx 24rpx; border-radius: 40rpx; border: 1rpx solid #eee;
}
.tag-name { font-size: 24rpx; color: #666; }
.tag-count { font-size: 20rpx; color: #ff5a5f; margin-left: 8rpx; font-weight: bold; }

/* 底部操作 */
.footer-bar {
  position: fixed; bottom: 0; left: 0; width: 100%; background: #fff;
  padding: 20rpx 40rpx; box-sizing: border-box; display: flex; gap: 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  justify-content: center;
}
.btn-primary, .btn-secondary { flex: 1; border-radius: 50rpx; font-size: 30rpx; font-weight: bold; padding: 22rpx 0; line-height: 1.5; }
.btn-primary { background: #333; color: #fff; }
.btn-secondary { background: #f8f9fa; color: #666; border: 1rpx solid #eee; }