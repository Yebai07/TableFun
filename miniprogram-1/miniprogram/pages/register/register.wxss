/* pages/register/register.wxss */
.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  padding-bottom: 80rpx;
}

/* 页面标题 */
.page-header {
  margin-bottom: 40rpx;
}
.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
}
.subtitle {
  font-size: 24rpx;
  color: #cccccc;
  font-family: Arial, sans-serif;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}
.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  padding: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
}
.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f5f5f5;
}
.edit-badge {
  position: absolute;
  right: 0;
  bottom: 10rpx;
  width: 50rpx;
  height: 50rpx;
  background: #333333;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 4rpx solid #ffffff;
}

/* 卡片和表单 */
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.form-item { margin-bottom: 30rpx; }
.form-row { display: flex; gap: 30rpx; }
.flex-1 { flex: 1; }

.label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.textarea-field {
  width: 100%;
  height: 140rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  align-items: center;
  height: 88rpx;
  gap: 30rpx;
}
.radio-label {
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
}

/* 标签样式 (继承 rate-user 风格) */
.section-header { margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: bold; color: #333; }

.tags-wrapper {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.tag {
  padding: 14rpx 32rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 500;
  background-color: #f5f5f5;
  color: #666666;
  transition: all 0.2s ease;
}
.tag-selected {
  background-color: #333333;
  color: #ffffff;
  transform: scale(1.05);
}

.custom-input-box { display: flex; gap: 20rpx; }
.custom-input { flex: 1; }
.btn-add {
  margin: 0 !important;
  width: 140rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  background: #eeeeee;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 16rpx;
  padding: 0;
}

/* 底部按钮 */
.bottom-action { margin-top: 60rpx; }
.btn-primary {
  background: #333333;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 96rpx;
  line-height: 96rpx;
  width: 100% !important;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}
.btn-primary:active { transform: scale(0.98); opacity: 0.9; }

/* ================= 头像选择弹窗样式 ================= */
.popup-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100vh; background: rgba(0, 0, 0, 0.6); z-index: 900; backdrop-filter: blur(4rpx); }
.avatar-popup { position: fixed; bottom: 0; left: 0; width: 100%; background: #ffffff; border-radius: 40rpx 40rpx 0 0; padding: 40rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); box-sizing: border-box; z-index: 999; animation: slideUp 0.3s ease; }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
.popup-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.popup-title { font-size: 34rpx; font-weight: bold; color: #333; }
.close-btn { font-size: 44rpx; color: #999; padding: 0 20rpx; margin-right: -20rpx; }
.avatar-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30rpx 20rpx; justify-items: center; }
.avatar-option { width: 130rpx; height: 130rpx; border-radius: 50%; overflow: hidden; border: 6rpx solid transparent; transition: all 0.2s ease; background: #f5f5f5; }
.avatar-option image { width: 100%; height: 100%; }
.avatar-option.selected { border-color: #333333; transform: scale(1.08); box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1); }