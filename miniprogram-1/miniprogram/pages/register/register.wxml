<view class="page-container">

<view class="page-header">
  <text class="title">创建你的档案</text>
  <text class="subtitle">Create Your Profile</text>
</view>

<view class="avatar-section">
  <view class="avatar-wrapper" bindtap="chooseAvatar">
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
    <view class="edit-badge">📷</view>
  </view>
</view>

<view class="section-card">
  <view class="form-item">
    <text class="label">昵称</text>
    <input class="input-field" placeholder="起个响亮的名字" value="{{nickname}}" bindinput="inputNickname"></input>
  </view>
  
  <view class="form-item">
    <text class="label">个性签名</text>
    <textarea class="textarea-field" placeholder="介绍一下自己吧..." value="{{bio}}" bindinput="inputBio"></textarea>
  </view>

  <view class="form-row">
    <view class="form-item flex-1">
      <text class="label">性别</text>
      <radio-group class="radio-group" bindchange="chooseGender">
        <label class="radio-label"><radio value="1" checked="{{gender == 1}}" color="#333"/> 男</label>
        <label class="radio-label"><radio value="2" checked="{{gender == 2}}" color="#333"/> 女</label>
      </radio-group>
    </view>
    <view class="form-item flex-1">
      <text class="label">年龄</text>
      <input class="input-field" placeholder="例: 20" value="{{age}}" bindinput="inputAge"></input>
    </view>
  </view>

  <view class="form-row">
    <view class="form-item flex-1">
      <text class="label">MBTI</text>
      <input class="input-field" placeholder="例: ENTP" value="{{mbti}}" bindinput="inputMbti"></input>
    </view>
    <view class="form-item flex-1">
      <text class="label">常驻地区</text>
      <input class="input-field" placeholder="例: 郫都区" value="{{region}}" bindinput="inputRegion"></input>
    </view>
  </view>
</view>

<view class="section-card">
  <view class="section-header">
    <text class="section-title">给自己贴标签</text>
  </view>
  
  <view class="tags-wrapper">
    <view 
      wx:for="{{processedTags}}" 
      wx:key="name" 
      class="tag {{item.selected ? 'tag-selected' : ''}}"
      data-tag="{{item.name}}" 
      bindtap="selectTag"
    >
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="custom-input-box">
    <input class="input-field custom-input" placeholder="自定义标签 (最多6字)" maxlength="6" value="{{customTag}}" bindinput="inputCustomTag"></input>
    <button class="btn-add" bindtap="addCustomTag">添加</button>
  </view>
</view>

<view class="bottom-action">
  <button class="btn-primary" bindtap="register">开启拼车之旅</button>
</view>

</view>

<view class="popup-mask" wx:if="{{showAvatarPopup}}" bindtap="closeAvatarPopup"></view>
<view class="avatar-popup" wx:if="{{showAvatarPopup}}">
<view class="popup-header">
  <text class="popup-title">选择头像</text>
  <text class="close-btn" bindtap="closeAvatarPopup">×</text>
</view>
<view class="avatar-grid">
  <view class="avatar-option {{avatarUrl === item ? 'selected' : ''}}" wx:for="{{avatarList}}" wx:key="*this" bindtap="selectAvatar" data-url="{{item}}">
    <image src="{{item}}" mode="aspectFill"></image>
  </view>
</view>
</view>