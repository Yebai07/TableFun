/* pages/detail.wxss */page {
  background-color: #f8f9fa;
}

/* 顶部大图 */
.banner {
  width: 100%;
  height: 560rpx;
  display: block;
}

/* 详情卡片（向上浮动遮盖图片边缘） */
.info-section {
  background: #ffffff;
  padding: 40rpx 30rpx;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx; /* 关键：向上偏移，盖住图片 */
  position: relative;
  min-height: 600rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff5a5f;
  margin-left: 20rpx;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.tag {
  font-size: 26rpx;
  color: #5b86e5;
  background: rgba(91, 134, 229, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.desc-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

/* 底部操作栏 */
.bottom-space {
  height: 160rpx; /* 防止内容被底部按钮挡住 */
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); /* 适配苹果全面屏底部黑条 */
}

.btn-primary {
  background: #333333; /* 酷炫的黑色按钮 */
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  width: 100%;
  padding: 24rpx 0;
  line-height: 1.5;
}

.loading-state {
  text-align: center;
  padding-top: 40vh;
  color: #999;
}

/* ===== 弹窗样式 ===== */
.mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
}

.popup-panel {
  position: fixed;
  bottom: -100%; /* 默认隐藏在底部下面 */
  left: 0; width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  transition: bottom 0.3s ease; /* 丝滑的弹出动画 */
  padding-bottom: env(safe-area-inset-bottom);
}

.popup-panel.show {
  bottom: 0; /* 激活时升起 */
}

.popup-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 40rpx 40rpx 20rpx;
}

.popup-title { font-size: 36rpx; font-weight: bold; color: #333; }
.popup-close { font-size: 40rpx; color: #999; padding: 10rpx; }

.form-content { padding: 0 40rpx; }

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #eee;
}

.label {
  font-size: 28rpx; color: #666; margin-bottom: 16rpx; display: block;
}

.picker-value {
  font-size: 32rpx; color: #333; font-weight: 500;
}
.picker-value.placeholder { color: #ccc; font-weight: normal; }

.textarea-input {
  width: 100%; height: 160rpx; background: #f8f9fa;
  border-radius: 16rpx; padding: 20rpx; box-sizing: border-box;
  font-size: 28rpx; margin-top: 10rpx;
}

.popup-footer { padding: 40rpx; }

.btn-submit {
  background: #ff5a5f; color: #fff; border-radius: 50rpx;
  font-size: 32rpx; font-weight: bold; width: 100%; padding: 24rpx 0;
}