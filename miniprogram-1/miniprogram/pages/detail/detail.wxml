<view class="page-container" wx:if="{{!isLoading}}">
  <image class="banner" src="{{scriptInfo.bannerUrl}}" mode="aspectFill"></image>

  <view class="info-section">
    <view class="title-row">
      <text class="title">{{scriptInfo.title}}</text>
      <text class="price">¥{{scriptInfo.price}}</text>
    </view>
    
    <view class="tags-row">
      <text class="tag">{{scriptInfo.type}}</text>
      <text class="tag">{{scriptInfo.players}}</text>
    </view>
    
    <view class="desc-box">
      <text class="desc-title">剧本简介</text>
      <text class="desc-content">{{scriptInfo.description}}</text>
    </view>
  </view>

  <view class="bottom-space"></view>

  <view class="bottom-bar">
    <button class="btn-primary" bindtap="openPopup">发起拼本</button>
  </view>
</view>

<view class="loading-state" wx:else>
  <text>正在加载剧本档案...</text>
</view>

<view class="mask" wx:if="{{showPopup}}" bindtap="closePopup"></view>

<view class="popup-panel {{showPopup ? 'show' : ''}}">
  <view class="popup-header">
    <text class="popup-title">发起拼本</text>
    <text class="popup-close" bindtap="closePopup">✕</text>
  </view>

  <view class="form-content">
    <view class="form-item">
      <text class="label">发车日期</text>
      <picker mode="date" value="{{formDate}}" start="{{today}}" bindchange="onDateChange">
        <view class="picker-value {{formDate ? '' : 'placeholder'}}">
          {{formDate || '请选择发车日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">发车时间</text>
      <picker mode="time" value="{{formTime}}" bindchange="onTimeChange">
        <view class="picker-value {{formTime ? '' : 'placeholder'}}">
          {{formTime || '请选择发车时间'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">锁车规则 (防跳车)</text>
      <picker mode="selector" range="{{lockOptions}}" value="{{lockIndex}}" bindchange="onLockChange">
        <view class="picker-value">
          {{lockOptions[lockIndex]}}
        </view>
      </picker>
    </view>

    <view class="form-item" style="border-bottom: none;">
      <text class="label">搭子意向 / 备注</text>
      <textarea class="textarea-input" placeholder="例如：需要全员硬核推土机，准时不鸽，可自带零食..." 
                value="{{notes}}" bindinput="onNotesInput" cursor-spacing="100"></textarea>
    </view>
  </view>

  <view class="popup-footer">
    <button class="btn-submit" bindtap="submitTeamup">确认发起</button>
  </view>
</view>