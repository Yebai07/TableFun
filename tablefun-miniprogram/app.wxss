/* 全局样式 - 清新白色主题 */
/* 小程序中 page 对应整个页面的根节点，相当于 HTML 中的 body */
page {
  background-color: #f5f5f5; /* 页面整体背景色（浅灰色），和 app.json 配置一致 */
  color: #333; /* 全局默认文字颜色（深灰色，比纯黑更柔和） */
  /* 全局字体配置：优先使用系统字体，保证多端显示一致、美观 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 主题色 - 基础文字色类 */
.theme-primary {
  color: #4CAF50; /* 主色调（绿色），和 app.json 导航栏/选中标签色一致 */
}
.theme-secondary {
  color: #2196F3; /* 辅助色（蓝色），用于次要强调 */
}
.theme-accent {
  color: #FF9800; /* 强调色（橙色），用于突出提醒/重点 */
}

/* 按钮样式 - 主按钮 */
.btn-primary {
  /* 渐变背景：从亮绿到深绿，增加视觉层次感 */
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff; /* 文字白色 */
  border: none; /* 去掉边框 */
  border-radius: 50rpx; /* 超大圆角（50rpx），实现胶囊按钮效果 */
  padding: 24rpx 48rpx; /* 内边距：上下24rpx，左右48rpx */
  font-size: 32rpx; /* 字体大小（小程序常用rpx做单位，适配不同屏幕） */
  font-weight: bold; /* 文字加粗 */
  /* 轻微阴影：增强立体感，阴影颜色和主色一致，透明度0.3 */
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

/* 主按钮按下状态 */
.btn-primary:active {
  transform: scale(0.98); /* 按下时缩小到98%，模拟按压反馈 */
}

/* 按钮样式 - 次要按钮 */
.btn-secondary {
  background: #fff; /* 白色背景 */
  color: #4CAF50; /* 文字用主色调绿色 */
  border: 2rpx solid #4CAF50; /* 2rpx宽的绿色边框 */
  border-radius: 50rpx; /* 和主按钮一致的超大圆角 */
  padding: 24rpx 48rpx; /* 内边距和主按钮一致，保证大小统一 */
  font-size: 32rpx; /* 字体大小一致 */
}

/* 卡片样式 - 内容容器 */
.card {
  background: #fff; /* 白色背景 */
  border-radius: 20rpx; /* 圆角（20rpx），比按钮小，更适合卡片 */
  padding: 30rpx; /* 内边距，保证内容和边框有间距 */
  margin-bottom: 24rpx; /* 底部外边距，卡片之间留出空隙 */
  /* 轻微阴影：弱化的阴影，仅增加一点点立体感，不突兀 */
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 输入框样式 */
.input {
  background: #fff; /* 白色背景 */
  border: none; /* 去掉默认边框 */
  border-radius: 12rpx; /* 小圆角，符合输入框常见设计 */
  padding: 24rpx; /* 内边距，保证输入文字不贴边 */
  color: #333; /* 输入文字颜色 */
  font-size: 28rpx; /* 输入框字体比按钮稍小，更适合阅读 */
}

/* 标签样式 - 基础标签 */
.tag {
  display: inline-block; /* 行内块元素：既可以并排显示，又能设置宽高/内边距 */
  padding: 8rpx 20rpx; /* 小内边距，适合标签尺寸 */
  border-radius: 20rpx; /* 圆角，让标签更圆润 */
  font-size: 24rpx; /* 小字体，标签文字不需要太大 */
  margin-right: 12rpx; /* 右侧外边距，标签之间留出空隙 */
  margin-bottom: 12rpx; /* 底部外边距，多行标签时留出空隙 */
}

/* 难度标签：橙色系（暖色调，对应强调色） */
.tag-difficulty {
  background: #FFF3E0; /* 浅橙色背景 */
  color: #FF9800; /* 橙色文字 */
}

/* 类型标签：蓝色系（冷色调，对应辅助色） */
.tag-type {
  background: #E3F2FD; /* 浅蓝色背景 */
  color: #2196F3; /* 蓝色文字 */
}

/* 人数标签：绿色系（主色调） */
.tag-player {
  background: #E8F5E9; /* 浅绿色背景 */
  color: #4CAF50; /* 绿色文字 */
}

/* 底部安全区 - 适配异形屏（如iPhone底部刘海/小黑条） */
.safe-area-bottom {
  /* 兼容旧版iOS */
  padding-bottom: constant(safe-area-inset-bottom);
  /* 兼容新版iOS */
  padding-bottom: env(safe-area-inset-bottom);
}