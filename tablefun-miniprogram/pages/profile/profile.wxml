<!--pages/profile/profile.wxml-->
<view class="profile-container">
  <!-- 未登录状态 -->
  <view class="not-logged-in" wx:if="{{!userInfo}}">
    <view class="login-bg">
      <text class="bg-icon">🎭</text>
    </view>
    <view class="login-content">
      <text class="welcome-text">欢迎来到桌趣</text>
      <text class="sub-text">与好友一起体验剧本杀的乐趣</text>
      <button class="btn-login" open-type="getUserInfo" bindgetuserinfo="handleLogin">
        <text class="btn-icon">👤</text>
        微信登录
      </button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:else>
    <!-- 用户信息 -->
    <view class="user-header">
      <view class="avatar-section" bindtap="editAvatar">
        <view class="avatar-wrapper">
          <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          <view class="avatar-edit">✎</view>
        </view>
      </view>
      <view class="info-section">
        <text class="user-name">{{userInfo.nickname}}</text>
        <text class="user-id">ID: {{userInfo.id}}</text>
      </view>
      <view class="action-section">
        <button class="btn-edit" bindtap="editProfile">编辑</button>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{stats.playCount}}</text>
        <text class="stat-label">游戏次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.winCount}}</text>
        <text class="stat-label">胜利次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.roomCount}}</text>
        <text class="stat-label">创建房间</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.collectCount}}</text>
        <text class="stat-label">收藏剧本</text>
      </view>
    </view>

    <!-- 等级进度 -->
    <view class="level-card">
      <view class="level-header">
        <view class="level-info">
          <text class="level-text">Lv.{{userInfo.level || 1}}</text>
          <text class="level-name">{{getLevelName(userInfo.level || 1)}}</text>
        </view>
        <text class="level-exp">{{stats.exp}}/{{getNextLevelExp(userInfo.level || 1)}} 经验</text>
      </view>
      <progress class="level-progress" percent="{{levelPercent}}" active stroke-width="8" activeColor="#4CAF50" backgroundColor="#f0f0f0" />
    </view>

    <!-- 功能列表 -->
    <view class="menu-list">
       <!-- 新增：私信入口 -->
  <view class="menu-item" bindtap="goToChatList">
    <view class="menu-icon">💬</view>
    <text class="menu-title">我的私信</text>
    <text class="menu-arrow">→</text>
  </view>
      <view class="menu-item" bindtap="goToPage" data-page="my-rooms">
        <view class="menu-icon">🏠</view>
        <text class="menu-title">我的房间</text>
        <text class="menu-count">{{stats.roomCount}}</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-item" bindtap="goToPage" data-page="game-history">
        <view class="menu-icon">📜</view>
        <text class="menu-title">游戏记录</text>
        <text class="menu-count">{{stats.playCount}}</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-item" bindtap="goToPage" data-page="achievements">
        <view class="menu-icon">🏆</view>
        <text class="menu-title">成就系统</text>
        <text class="menu-count">{{stats.achievementCount}}</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-item" bindtap="goToPage" data-page="wallet">
        <view class="menu-icon">💰</view>
        <text class="menu-title">我的钱包</text>
        <text class="menu-count">{{stats.coins}}金币</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-divider"></view>

      <view class="menu-item" bindtap="goToPage" data-page="settings">
        <view class="menu-icon">⚙️</view>
        <text class="menu-title">设置</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-item" bindtap="goToPage" data-page="feedback">
        <view class="menu-icon">💬</view>
        <text class="menu-title">意见反馈</text>
        <text class="menu-arrow">→</text>
      </view>

      <view class="menu-item" bindtap="goToPage" data-page="about">
        <view class="menu-icon">ℹ️</view>
        <text class="menu-title">关于我们</text>
        <text class="menu-arrow">→</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="btn-logout" bindtap="handleLogout">退出登录</button>
    </view>
  </view>
</view>
