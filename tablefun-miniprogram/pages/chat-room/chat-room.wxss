/* pages/chat-room/chat-room.wxss */
.chat-room-container {
  min-height: 100vh;
  background-color: #1a1a2e;
  display: flex;
  flex-direction: column;
}

/* 聊天头部 */
.chat-header {
  height: 100rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}
.back-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}
.target-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.target-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
}

/* 聊天内容区 */
.chat-content {
  flex: 1;
  padding: 30rpx;
}
.msg-item {
  display: flex;
  margin-bottom: 30rpx;
  max-width: 100%;
}
.left {
  justify-content: flex-start;
}
.right {
  justify-content: flex-end;
}
.msg-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin: 0 16rpx;
}
.msg-bubble {
  max-width: 60%;
  padding: 20rpx;
  border-radius: 16rpx;
  position: relative;
}
.left-bubble {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  border-bottom-left-radius: 4rpx;
}
.right-bubble {
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
  color: #fff;
  border-bottom-right-radius: 4rpx;
}
.msg-text {
  font-size: 28rpx;
  line-height: 1.5;
}
.msg-invite {
  font-size: 26rpx;
  line-height: 1.5;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.invite-label {
  color: #e84545;
  font-weight: bold;
}
.right-invite .invite-label {
  color: #fff;
}
.accept-invite {
  padding: 8rpx 16rpx;
  background: #4CAF50;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 24rpx;
  margin-top: 8rpx;
  width: 120rpx;
}
.msg-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  position: absolute;
  bottom: 8rpx;
  right: 16rpx;
}

/* 输入区 */
.input-area {
  height: 120rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}
.msg-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 0 30rpx;
  color: #fff;
  font-size: 28rpx;
}
.send-btn, .invite-btn {
  width: 120rpx;
  height: 80rpx;
  border-radius: 40rpx;
  color: #fff;
  border: none;
  font-size: 28rpx;
  margin-left: 16rpx;
}
.send-btn {
  background: rgba(255, 255, 255, 0.2);
}
.invite-btn {
  background: linear-gradient(135deg, #e84545 0%, #c0392b 100%);
}